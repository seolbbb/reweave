      },
      "msg-2": {
        "id": "msg-2",
        "message": {
          "author": {"role": "assistant"},
          "content": {"parts": ["The Zettelkasten method is a note-taking system developed by Niklas Luhmann. It uses atomic notes connected through links to build a network of knowledge."]},
          "create_time": 1707570960.0
        },
        "parent": "msg-1",
        "children": ["msg-3"]
      },
      "msg-3": {
        "id": "msg-3",
        "message": {
          "author": {"role": "user"},
          "content": {"parts": ["How do I implement it digitally?"]},
          "create_time": 1707571020.0
        },
        "parent": "msg-2",
        "children": ["msg-4"]
      },
      "msg-4": {
        "id": "msg-4",
        "message": {
          "author": {"role": "assistant"},
          "content": {"parts": ["Tools like Obsidian, Logseq, or Roam Research implement the Zettelkasten digitally. They use bidirectional links and graph views to visualize connections between notes."]},
          "create_time": 1707571080.0
        },
        "parent": "msg-3",
        "children": []
      }
    }
  },
